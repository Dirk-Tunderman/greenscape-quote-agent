# Greenscape Quote Agent — environment variables
# Copy to .env.local for local dev. All vars are loaded server-side except the NEXT_PUBLIC_* ones.

# Anthropic (5-skill agent chain — Sonnet 4.5 + Haiku 4.5)
ANTHROPIC_API_KEY=

# Supabase (server-side service role — bypasses RLS in API routes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (browser — anon key, RLS-deny by default)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Deepgram (audio upload on /quotes/new → Nova-3 transcription)
DEEPGRAM_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
