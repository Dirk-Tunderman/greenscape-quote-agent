# Greenscape Quote Agent — environment variables
# Frontend (Chat B) does not require any of these to run with mocks.
# Chat A populates these when wiring real API routes.

# Anthropic
ANTHROPIC_API_KEY=

# Supabase (server-side; service role)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend (outbound email)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Greenscape Pro <quotes@greenscape.example>"

# Deepgram (audio upload on /quotes/new → transcript)
DEEPGRAM_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
